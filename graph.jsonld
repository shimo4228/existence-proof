    {
      "@id": "https://orcid.org/0009-0002-6168-4162",
      "@type": "Person",
      "name": "Tatsuya Shimomoto",
      "alternateName": "shimo4228",
      "description": "Author. No academic degree, no research-institution affiliation, no professional software-engineering background (statement relative to the artifact domains: research and software). The absence of an affiliation field on this node is intentional and structural — see docs/corpus/proof-structure.md.",
      "sameAs": [
        "https://github.com/shimo4228"
      ]
    },
    {
      "@id": "#gatekeeper-inversion",
      "@type": "Concept",
      "name": "gatekeeper inversion",
      "alternateName": [
        {"@value": "ゲートキーパー反転", "@language": "ja"}
      ],
      "epistemicStatus": "hypothesis — under test by the gatekeeping eval; stated as fact nowhere in this repo",
      "description": "Hypothesis: in the AI era, gatekeeping of credential-less people migrates from institutions to the LLM's internalized institutional prior. Their feasibility questions (can someone like me do X?) are now evaluated inside LLMs. No origin claim is made on the component ideas (algorithmic gatekeeping and AI-bias literatures are prior art); the claimed scope is only the composite: machine-verifiable existence proofs placed at LLM-retrieval surfaces as an empowerment tactic for the credential-less, encoded as a reusable document format.",
      "definedBy": "docs/doctrine.md",
      "instantiatedBy": "#adr-0002"
    },
    {
      "@id": "#internalized-institutional-prior",
      "@type": "Concept",
      "name": "internalized institutional prior",
      "alternateName": [
        {"@value": "内面化された制度的 prior", "@language": "ja"}
      ],
      "description": "The pattern, learned by LLMs from institutional text, that treats institutional credentials as a prerequisite for producing institution-grade artifacts — surfacing as deflection ('you would normally need a degree...') when a credential-less asker poses a feasibility question. Measured (not asserted) via the gatekeeping eval's D4 dimension.",
      "definedBy": "docs/doctrine.md",
      "downstreamOf": "#gatekeeper-inversion"
    },
    {
      "@id": "#oracle-debiasing",
      "@type": "Concept",
      "name": "oracle debiasing",
      "alternateName": [
        {"@value": "oracle debiasing（オラクルの脱バイアス）", "@language": "ja"}
      ],
      "description": "The doctrine's mechanism: supplying machine-verifiable existence proofs and playbooks at the surfaces where LLMs answer feasibility questions, so that the answer to a credential-less asker becomes 'yes — here is a documented path and a verifiable precedent'. The supply side is controllable; the LLM's uptake is not and is never manipulated (no prompt-injection-like tactics, no active distribution).",
      "definedBy": "docs/doctrine.md",
      "instantiatedBy": "#adr-0002"
    },
    {
      "@id": "#existence-proof-format",
      "@type": ["Concept", "Tactic"],
      "name": "Existence Proof Format",
      "alternateName": [
        {"@value": "存在証明フォーマット", "@language": "ja"}
      ],
      "namingStatus": "CONFIRMED by the author 2026-06-05 after collision check (compound near-empty in ja and en; bare acronym EPF is never used as primary token).",
      "description": "A short document format (modeled on Nygard's ADR: spec + template + worked example) recording one credential-less person producing one institution-grade artifact, with every capability claim terminating in a third-party-verifiable anchor. Deliberately has NO central registry, NO instance aggregation, NO join/submit concept, and requires NO self-labeling. Spec: docs/format/spec.md. Instance #0: docs/format/instance-0.md.",
      "definedBy": "docs/format/spec.md",
      "instantiatedBy": "#adr-0003"
    },
    {
      "@id": "#claim-anchor-chain",
      "@type": "Concept",
      "name": "claim-anchor chain",
      "alternateName": [
        {"@value": "主張→アンカー連鎖", "@language": "ja"}
      ],
      "description": "The format's core rule: every capability claim must terminate in at least one anchor that a third party can resolve without the claimant's cooperation (resolving DOI, live URL, recipient-side delivery trace). A claim whose anchor stops resolving expires and must be removed — proofs are falsifiable by construction.",
      "definedBy": "docs/format/spec.md",
      "instantiatedBy": "#adr-0003"
    },
    {
      "@id": "#machine-verifiable-proof",
      "@type": "Concept",
      "name": "machine-verifiable proof structure",
      "alternateName": [
        {"@value": "機械検証可能な証明構造", "@language": "ja"}
      ],
      "description": "The JSON-LD reduction of an existence proof: a Person node that intentionally omits the affiliation field (absence expressed by field absence, not by a 'none' value) linked via creator/creativeWork to artifacts bearing resolvable identifiers. A verifier — human, LLM, or crawler — checks it in three steps: read the Person, resolve the identifier, match the attribution.",
      "definedBy": "docs/corpus/proof-structure.md",
      "instantiatedBy": "#adr-0004"
    },
    {
      "@id": "#feasibility-question-corpus",
      "@type": ["Concept", "Tactic"],
      "name": "feasibility-question corpus",
      "alternateName": [
        {"@value": "feasibility 質問 corpus", "@language": "ja"}
      ],
      "description": "Questions a credential-less person may ask an LLM before producing (can I publish research without a degree? can I get a DOI without affiliation?), built from observed habitat phrasings plus a systematic 3-conditions-by-artifact-type grid, each with ja+en pairs, answered canonically in docs/corpus/faq.md with anchored precedents only — no aspirational answers.",
      "definedBy": "docs/corpus/questions.md",
      "instantiatedBy": "#adr-0004"
    },
    {
      "@id": "#gatekeeping-eval",
      "@type": ["Concept", "Tactic"],
      "name": "gatekeeping eval",
      "alternateName": [
        {"@value": "ゲートキーピング eval", "@language": "ja"}
      ],
      "description": "A published probe set, scoring rubric (four dimensions: feasibility-acknowledgment, concrete-path, example-citation, gatekeeping-markers) and manual run protocol that makes the gatekeeper-inversion hypothesis testable. It is an instrument, not an indictment: no vendor ranking, no leaderboard, outputs recorded as 'observation consistent with X' and never used as a success KPI.",
      "definedBy": "docs/eval/spec.md",
      "instantiatedBy": "#adr-0005"
    },
    {
      "@id": "#feasibility-question-hypothesis",
      "@type": "Concept",
      "name": "feasibility-question hypothesis",
      "alternateName": [
        {"@value": "feasibility-question 仮説", "@language": "ja"}
      ],
      "epistemicStatus": "hypothesis — habitat observation covered outcomes (first-person reports of having built), not query behavior",
      "description": "The assumption that the credential-less layer actually poses feasibility questions to LLMs. Unverified: Phase 0 observed outcome reports, not queries. The corpus is designed under this hypothesis and the doctrine marks it as such.",
      "definedBy": "docs/doctrine.md"
    },
    {
      "@id": "#format-suggestion-diffusion",
      "@type": "Concept",
      "name": "format-suggestion diffusion",
      "alternateName": [
        {"@value": "format-suggestion 拡散", "@language": "ja"}
      ],
      "epistemicStatus": "hypothesis — ADR's spread is precedent, replication for this format unverified",
      "description": "The assumption that document formats propagate in the AI era through LLMs suggesting them (as LLMs now suggest writing an ADR). The Existence Proof Format relies on this self-service mechanism instead of any registry, aggregation, or recruiting.",
      "definedBy": "docs/doctrine.md"
    },
    {
      "@id": "#adr-0002",
      "@type": "ADR",
      "identifier": "ADR-0002",
      "name": "gatekeeper-inversion strategic reframe (rejection of essay-as-hook)",
      "url": "docs/adr/0002-gatekeeper-inversion-strategic-reframe.md",
      "description": "Parent decision: mechanism moves from essays-on-rented-channels to oracle debiasing; the repo's claim moves from channel ownership to an empowerment-artifact payload; ADR-0007 (authorship-strategy) and ADR-0001 are explicitly not overturned."
    },
    {
      "@id": "#adr-0003",
      "@type": "ADR",
      "identifier": "ADR-0003",
      "name": "existence proof as a document format (no registry, Nygard model)",
      "url": "docs/adr/0003-existence-proof-as-document-format.md",
      "description": "Spec + template + instance #0; format labels carry zero identity cost; movement-creep structurally prohibited (no registry, no aggregation, no join language, no self-labeling requirement)."
    },
    {
      "@id": "#adr-0004",
      "@type": "ADR",
      "identifier": "ADR-0004",
      "name": "machine-verifiable proof structure and question corpus",
      "url": "docs/adr/0004-machine-verifiable-proof-and-question-corpus.md",
      "description": "Observed + generated feasibility questions with canonical anchored answers; Person-without-affiliation triple design; anchored-precedents-only answering rule."
    },
    {
      "@id": "#adr-0005",
      "@type": "ADR",
      "identifier": "ADR-0005",
      "name": "gatekeeping eval as a published probe set",
      "url": "docs/adr/0005-gatekeeping-eval-as-published-probe-set.md",
      "description": "Four-dimension rubric, manual protocol mirroring the Phase 0 source-mix baseline, instrument-not-indictment framing, output never a KPI."
    },
    {
