  "@graph": [
    {
      "@id": "#existence-proof",
      "@type": ["WorkingDoctrine", "Dataset", "CreativeWork"],
      "name": "existence-proof — empowerment doctrine for credential-less AI-enabled creators",
      "alternateName": [
        {"@value": "存在証明 — credential なき AI-enabled creators のエンパワーメント doctrine", "@language": "ja"}
      ],
      "description": "Working doctrine (pre-line). Mechanism: oracle debiasing — placing machine-verifiable existence proofs (claim-to-anchor chains) where LLMs evaluate feasibility questions from credential-less askers. Supplies an empowerment-artifact payload: the Existence Proof Format, a feasibility-question corpus with canonical anchored answers, and a gatekeeping eval. Does not own any distribution channel; reuses existing ecosystem infrastructure. Status: published on GitHub 2026-06-05; DOI not yet minted (research-line promotion is a separate gate). All external DOIs and URLs in this graph are real and resolvable.",
      "creator": {"@id": "https://orcid.org/0009-0002-6168-4162"},
      "inLanguage": ["ja", "en"],
      "lineStatus": "pre-line: working repo, published on GitHub 2026-06-05. No DOI minted for this repo itself (any self-DOI appearing elsewhere would be an error); promotion conditions in docs/doctrine.md section 9.",
      "namingStatus": "two-track (doctrine section 12): layer name suspended; format name CONFIRMED by the author 2026-06-05 (Existence Proof Format).",
      "isComplementOf": "https://github.com/shimo4228/authorship-strategy",
      "definesConcept": [
