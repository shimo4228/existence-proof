    },
    {
      "@id": "https://github.com/shimo4228/authorship-strategy",
      "@type": "CreativeWork",
      "name": "Authorship Strategy",
      "identifier": "10.5281/zenodo.20263316",
      "creator": {"@id": "https://orcid.org/0009-0002-6168-4162"},
      "description": "Complement of this doctrine: same infrastructure (llms.txt, graph.jsonld, DOI, distinctive terminology), different payload and beneficiary — authorship-strategy diffuses the author's attribution through LLM-mediated channels; existence-proof supplies empowerment artifacts to the credential-less layer. This repo deliberately does NOT use the sibling relation (sibling is reserved for DOI-registered research lines; this repo is pre-line)."
    }
